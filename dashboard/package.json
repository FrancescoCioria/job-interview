{
  "name": "toolforge-deployment-inspector",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Mini dashboard to inspect Toolforge deployment status and logs",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite",
    "build": "vite build && tsc -p tsconfig.server.json",
    "start": "node dist/server/index.js",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit"
  },
  "dependencies": {
    "express": "4.21.2",
    "cors": "2.8.5"
  },
  "devDependencies": {
    "@types/express": "5.0.1",
    "@types/cors": "2.8.17",
    "@types/node": "22.13.14",
    "@types/react": "19.0.12",
    "@types/react-dom": "19.0.4",
    "@vitejs/plugin-react": "4.3.4",
    "@tanstack/react-query": "5.67.2",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-router-dom": "7.3.0",
    "tailwindcss": "4.0.14",
    "@tailwindcss/vite": "4.0.14",
    "clsx": "2.1.1",
    "date-fns": "4.1.0",
    "concurrently": "9.1.2",
    "tsx": "4.19.3",
    "typescript": "5.7.3",
    "vite": "6.2.2"
  }
}
