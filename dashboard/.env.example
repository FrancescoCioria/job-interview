# Dashboard configuration — copy to .env and fill in your values:
#
#   cp .env.example .env

# API base URL — point to Toolforge, a staging server, or localhost
TOOLFORGE_API_URL=https://api.svc.toolforge.org

# Your tool name (passed in API paths, e.g. /components/v1/tool/{name}/...)
TOOLFORGE_TOOL_NAME=my-tool

# Deploy token (sent in Api-Key header — keep secret, never commit .env)
# On Toolforge, generate with: toolforge deploy generate-token
TOOLFORGE_DEPLOY_TOKEN=
