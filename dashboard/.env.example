# Dashboard configuration for connecting to a real Toolforge API.
# Copy this file to .env and fill in your values:
#
#   cp .env.example .env
#
# To generate a deploy token, run on Toolforge:
#
#   toolforge deploy generate-token
#

# Required — your Toolforge tool name (e.g. "my-tool")
TOOLFORGE_TOOL_NAME=

# Required — deploy token (keep this secret, never commit .env)
TOOLFORGE_DEPLOY_TOKEN=

# Optional — override the API base URL
# TOOLFORGE_API_URL=https://api.svc.toolforge.org

# Optional — server port (default: 3000)
# PORT=3000
